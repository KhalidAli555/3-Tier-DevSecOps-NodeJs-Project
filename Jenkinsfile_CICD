pipeline {
    agent any
    tools {
      nodejs 'nodejs23' 
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {
        stage('GitCheckout') {
            steps {
                git branch: 'main', url: 'https://github.com/KhalidAli555/3-Tier-DevSecOps-NodeJs-Project.git'
            }
        }
        
        stage('Frontend Compilation') {
            steps {
               dir('client') {
                    sh 'find . -name "*.js" -exec node --check {} +'
                }
            }
        }
        stage('Backend Compilation') {
            steps {
                dir('api') {
                    sh 'find . -name "*.js" -exec node --check {} +'
                }
            }
        }
        stage('GitLeaks Scan') {
            steps {
                sh 'gitleaks detect --source ./client --exit-code 1'
                sh 'gitleaks detect --source ./api --exit-code 1'
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar') {
                    sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=NodeJS-Project \
                            -Dsonar.projectKey=NodeJS-Project '''
                }
            }
        }
        stage('Quality gate check') {
            steps {
                timeout(time: 1, unit: 'HOURS') {
                waitForQualityGate abortPipeline: false, credentialsId: 'sonarqube-token'
        }
            }
        }
        
         stage('Trivy FS Scan') {
            steps {
                sh 'trivy fs --format table -o fs-report.html .'
            }
        }
        stage('Build-Tag & Push Backend Docker Image') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'dockerhub-cred') {
                        dir('api') {
                            sh 'docker build -t khalidale/backend:latest .'
                            sh 'trivy image --format table -o backend-image-report.html khalidale/backend:latest '
                            sh 'docker push khalidale/backend:latest'
                           
                        }
                    }
                }
            }
        }  
            
        stage('Build-Tag & Push Frontend Docker Image') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'dockerhub-cred') {
                        dir('client') {
                            sh 'docker build -t khalidale/frontend:latest .'
                            sh 'trivy image --format table -o frontend-image-report.html khalidale/frontend:latest '
                            sh 'docker push khalidale/frontend:latest'
                        }
                    }
                }
            }
             
        }  
       
       stage('Deployment To k8s') {
            steps {
                script {
                    withKubeConfig(caCertificate: '', clusterName: '', contextName: '', credentialsId: 'k8s-token', namespace: '', restrictKubeConfigAccess: false, serverUrl: 'https://172.31.16.248:6443'){
                        
                        sh 'kubectl apply -f k8s/mysql/pv.yml'
                        sh 'kubectl apply -f k8s/mysql/pvc.yml'
                        sh 'kubectl apply -f k8s/mysql/config.yml'
                        sh 'kubectl apply -f k8s/mysql/config1.yml'
                        sh 'kubectl apply -f k8s/mysql/secret.yml'
                        sh 'kubectl apply -f k8s/mysql/deployment.yml'
                        sh 'kubectl apply -f k8s/mysql/service.yml'
                        sh 'kubectl apply -f k8s/backend/deployment.yml'
                        sh 'kubectl apply -f k8s/backend/service.yml'
                        sh 'kubectl apply -f k8s/frontend/deployment.yml'
                        sh 'kubectl apply -f k8s/frontend/service.yml'
                    }
                }
            }
        } 
    }
}
